# UPOU AI HelpDesk — environment variables
#
# Copy to .env and fill in real values. These are read by the build
# scripts at deploy time. The Apache vhosts use SetEnv with similar
# values (see docs/deploy/upou-helpdesk.conf and admin/docs/upou-admin.conf).

# AWS region — Learner Lab is locked to us-east-1
AWS_REGION=us-east-1

# Lambda function name (must already exist; bootstrap_aws.sh creates it)
LAMBDA_FUNCTION_NAME=ai-webapp-handler

# S3 bucket holding the policy index and interaction logs.
# IMPORTANT: bucket name only — no "s3://" prefix
S3_BUCKET=upou-helpdesk-2026-yourinitials
S3_PREFIX=logs/

# DynamoDB table for escalation tickets
DDB_TICKETS_TABLE=upou-helpdesk-tickets

# OpenAI-compatible chat endpoint.
# For the UPOU class proxy use:
#   OPENAI_BASE_URL=https://is215-openai.upou.io/v1
# For real OpenAI:
#   OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://is215-openai.upou.io/v1
OPENAI_MODEL=gpt-4o-mini

# Keyword search threshold (0..1). Lower = more lenient.
KEYWORD_THRESHOLD=0.15

# Local MySQL credentials (Apache vhost reads these via SetEnv too)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=upou_helpdesk
DB_USER=upou_app
DB_PASS=change-me-to-a-strong-password

PORT=8000
APP_DEBUG=false
